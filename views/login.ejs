<!DOCTYPE html>
<html>
<head>
    <title>MarmitaTech - Login</title>
    <style>
        body { 
            font-family: sans-serif; 
            display: flex; 
            justify-content: center; 
            margin-top: 100px; 
            background: #f4f4f4; 
        }

        .container {
            text-align: center;
        }

        .logo {
            width: 140px;
            margin-bottom: 10px;
        }

        .restaurant-name {
            font-size: 26px;
            font-weight: bold;
            margin-bottom: 20px;
            color: #333;
        }

        form {
            background: white; 
            padding: 35px;              /* mais espaço interno */
            width: 380px;               /* largura maior */
            border-radius: 10px; 
            box-shadow: 0 0 15px rgba(0,0,0,0.15);
        }

        input {
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            border: 1px solid #ccc;
        }

        button {
            width: 100%;
            padding: 10px;
            border-radius: 6px;
            border: none;
            background-color: #ff7a00;
            color: white;
            font-weight: bold;
            cursor: pointer;
        }

        button:hover {
            background-color: #e66d00;
        }
    </style>
</head>
<body>
    <div class="container">
        <img src="logo.png" alt="Logo Restaurante" class="logo">
        <div class="restaurant-name">Restaurante Aalthair's</div>

        <form action="/login" method="POST">
            <h2>🥪 Login</h2>
            <input type="text" name="username" placeholder="Usuário" required><br><br>
            <input type="password" name="password" placeholder="Senha" required><br><br>
            <button type="submit">Entrar</button>
        </form>
    </div>
</body>
</html>