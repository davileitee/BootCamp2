<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<title>Aalthair's Food | Dashboard</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
    :root {
        --primary: #ff4500;
        --primary-light: #ff7f50;
        --secondary: #ffa500;
        --bg: #f4f7fb;
        --surface: #ffffff;
        --text-main: #0f172a;
        --text-muted: #64748b;
        --border: #e2e8f0;
        --radius-lg: 24px;
        --radius-md: 16px;
        --radius-sm: 8px;
        --shadow-sm: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        --shadow-md: 0 10px 25px -3px rgba(0, 0, 0, 0.08);
        --shadow-lg: 0 20px 40px -5px rgba(255, 69, 0, 0.15);
    }
    
    * { box-sizing: border-box; margin: 0; padding: 0; }
    
    body {
        font-family: 'Outfit', sans-serif;
        background-color: var(--bg);
        background-image: 
            radial-gradient(circle at 0% 0%, rgba(255, 127, 80, 0.08) 0%, transparent 40%),
            radial-gradient(circle at 100% 100%, rgba(255, 165, 0, 0.08) 0%, transparent 40%);
        background-attachment: fixed;
        color: var(--text-main);
        min-height: 100vh;
        padding: 40px 24px;
    }

    .container {
        max-width: 1280px;
        margin: 0 auto;
    }

    /* Header */
    .header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 48px;
        background: var(--surface);
        padding: 20px 32px;
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-sm);
        border: 1px solid rgba(255,255,255,0.8);
    }

    @media (max-width: 600px) {
        .header {
            flex-direction: column;
            gap: 16px;
            text-align: center;
        }
    }

    .brand {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .brand-icon {
        width: 48px;
        height: 48px;
        display: grid;
        place-items: center;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        border-radius: var(--radius-md);
        font-size: 1.5rem;
        box-shadow: 0 8px 16px rgba(255, 69, 0, 0.25);
    }

    .brand-title {
        font-size: 1.5rem;
        font-weight: 700;
        letter-spacing: -0.5px;
    }

    h1 {
        font-size: 1.25rem;
        font-weight: 500;
        color: var(--text-muted);
    }

    /* Grid Layout */
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
        gap: 32px;
    }

    /* Cards */
    .card {
        background: var(--surface);
        border-radius: var(--radius-lg);
        padding: 32px;
        box-shadow: var(--shadow-md);
        border: 1px solid rgba(255, 255, 255, 0.5);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        display: flex;
        flex-direction: column;
        max-height: 500px;
    }

    .card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-lg);
    }

    .card h3 {
        font-size: 1.35rem;
        margin-bottom: 24px;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 12px;
        color: var(--text-main);
    }

    /* CTA Card for Kanban */
    .card.cta-card {
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        color: white;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: relative;
        overflow: hidden;
        border: none;
    }
    
    .card.cta-card::before {
        content: '';
        position: absolute;
        top: -50%; left: -50%; width: 200%; height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.2) 0%, transparent 60%);
        opacity: 0;
        transition: opacity 0.5s ease;
    }
    .card.cta-card:hover::before {
        opacity: 1;
    }

    .card.cta-card h3 {
        color: white;
        font-size: 1.85rem;
        margin-bottom: 16px;
        z-index: 1;
    }

    .card.cta-card p {
        font-size: 1.1rem;
        opacity: 0.95;
        margin-bottom: 32px;
        max-width: 280px;
        z-index: 1;
        line-height: 1.5;
    }

    .btn-light {
        display: inline-block;
        background: white;
        color: var(--primary);
        padding: 16px 32px;
        border-radius: var(--radius-md);
        font-weight: 700;
        font-size: 1.05rem;
        text-decoration: none;
        transition: transform 0.2s, box-shadow 0.2s;
        z-index: 1;
    }
    .btn-light:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.15);
    }

    /* Forms & Inputs */
    .form-container {
        display: flex;
        flex-direction: column;
        flex: 1;
        justify-content: center;
    }

    .field {
        margin-bottom: 20px;
    }

    .field input {
        width: 100%;
        padding: 16px;
        border-radius: var(--radius-md);
        border: 1px solid var(--border);
        background: var(--bg);
        font-size: 1.05rem;
        font-family: inherit;
        color: var(--text-main);
        transition: all 0.2s ease;
    }

    .field input:focus {
        outline: none;
        border-color: var(--primary);
        background: white;
        box-shadow: 0 0 0 4px rgba(255, 69, 0, 0.1);
    }

    button {
        width: 100%;
        border: none;
        border-radius: var(--radius-md);
        padding: 16px;
        font-size: 1.05rem;
        font-weight: 600;
        font-family: inherit;
        color: white;
        background: linear-gradient(135deg, var(--primary), var(--secondary));
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 12px rgba(255, 69, 0, 0.2);
        margin-top: auto;
    }

    button:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(255, 69, 0, 0.3);
    }

    /* Lists */
    .list-container {
        flex: 1;
        overflow-y: auto;
        padding-right: 8px;
        margin-bottom: -8px; /* Offset padding */
    }
    
    .list-container::-webkit-scrollbar {
        width: 6px;
    }
    .list-container::-webkit-scrollbar-track {
        background: var(--bg); 
        border-radius: 10px;
    }
    .list-container::-webkit-scrollbar-thumb {
        background: #cbd5e1; 
        border-radius: 10px;
    }

    .item-row {
        display: flex;
        align-items: center;
        padding: 16px;
        background: var(--bg);
        border-radius: var(--radius-md);
        margin-bottom: 12px;
        border: 1px solid transparent;
        transition: border-color 0.2s ease, background 0.2s ease;
    }
    .item-row:hover {
        border-color: var(--border);
        background: #f1f5f9;
    }

    .item-icon {
        width: 44px; height: 44px;
        border-radius: 50%;
        background: rgba(255, 69, 0, 0.1);
        color: var(--primary);
        display: grid;
        place-items: center;
        margin-right: 16px;
        font-weight: 700;
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .item-details {
        flex: 1;
        min-width: 0; /* Prevents flex blowout */
    }

    .item-title {
        font-weight: 600;
        font-size: 1.05rem;
        margin-bottom: 4px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .item-subtitle {
        font-size: 0.9rem;
        color: var(--text-muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    /* Orders List specific adjustments */
    .order-item {
        flex-direction: column;
        align-items: flex-start;
        gap: 16px;
    }
    
    .order-header {
        display: flex;
        justify-content: space-between;
        width: 100%;
        align-items: flex-start;
    }

    .order-status {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: var(--primary);
        background: rgba(255, 69, 0, 0.1);
        flex-shrink: 0;
        margin-left: 12px;
    }

    .btn-secondary {
        background: transparent;
        color: var(--primary);
        border: 2px solid var(--primary);
        box-shadow: none;
        padding: 12px 16px;
        margin-top: 0;
    }
    .btn-secondary:hover {
        background: var(--primary);
        color: white;
        border-color: transparent;
        box-shadow: 0 4px 12px rgba(255, 69, 0, 0.2);
    }

    /* Footer */
    .footer {
        margin-top: 60px;
        font-size: 0.95rem;
        color: var(--text-muted);
        text-align: center;
        font-weight: 500;
    }
</style>
</head>
<body>
<div class="container">
    <div class="header">
        <div class="brand">
            <div class="brand-icon">🍽️</div>
            <div class="brand-title">Aalthair's Food</div>
        </div>
        <div style="display: flex; align-items: center; gap: 16px; flex-wrap: wrap; justify-content: center;">
            <h1 style="margin: 0;">Dashboard Administrativo</h1>
            <a href="/admin/export" class="btn-secondary" style="text-decoration: none; display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 12px; font-weight: 600;">
                📥 Baixar Relatório
            </a>
        </div>
    </div>

    <div class="grid">
        
        <!-- Novo Item -->
        <div class="card">
            <h3>✨ Novo Ingrediente</h3>
            <div class="form-container">
                <form action="/add-item" method="POST">
                    <div class="field">
                        <input type="text" name="name" placeholder="Nome (Ex: Batata Doce)" required>
                    </div>
                    <div class="field">
                        <input type="text" name="category" placeholder="Categoria (Ex: Carboidrato)">
                    </div>
                    <button type="submit">Cadastrar Item</button>
                </form>
            </div>
        </div>

        <!-- Itens Cadastrados -->
        <div class="card">
            <h3>📦 Itens em Estoque</h3>
            <div class="list-container">
                <% if(items.length === 0) { %>
                    <p style="color: var(--text-muted); text-align: center; margin-top: 20px;">Nenhum item cadastrado ainda.</p>
                <% } %>
                <% items.forEach(item => { %>
                    <div class="item-row" style="display: flex; align-items: center; gap: 16px;">
                        <div class="item-details" style="flex: 1; min-width: 0; padding-right: 12px;">
                            <div class="item-title" style="white-space: normal; font-size: 1.1rem; line-height: 1.2; margin-bottom: 4px;"><%= item.name %></div>
                            <div class="item-subtitle"><%= item.category || 'Sem categoria' %></div>
                        </div>
                        <!-- Botão de Criação Rápida de Pedido -->
                        <button class="btn-secondary" style="width: auto; flex-shrink: 0; margin-left: auto; padding: 8px 16px; font-size: 0.85rem;" onclick="createQuickOrder(<%= item.id %>, '<%= item.name %>')">Criar Pedido</button>
                    </div>
                <% }) %>
            </div>
        </div>

        <!-- Call to Action Kanban (Movido para destaque) -->
        <div class="card cta-card">
            <h3>Fluxo de Produção</h3>
            <p>Acompanhe e gerencie todos os pedidos em tempo real no painel Kanban interativo.</p>
            <a href="/kanban" class="btn-light">Acessar Kanban →</a>
        </div>

        <!-- Pedidos Ativos -->
        <div class="card">
            <h3>🔔 Pedidos Recentes</h3>
            <div class="list-container" id="orders-container">
                <% if(orders.length === 0) { %>
                    <p id="empty-orders-msg" style="color: var(--text-muted); text-align: center; margin-top: 20px;">Nenhum pedido no momento.</p>
                <% } %>
                <% orders.forEach(order => { %>
                    <div class="item-row order-item">
                        <div class="order-header">
                            <div class="item-details" style="flex: 1;">
                                <div class="item-title"><%= order.customer_name %></div>
                                <div class="item-subtitle">Marmita: <%= order.item_name || 'N/A' %></div>
                            </div>
                            <div class="order-status"><%= order.status %></div>
                        </div>
                        <% if (order.status === 'Entregue') { %>
                            <button class="btn-secondary" disabled style="opacity: 0.5; cursor: not-allowed; width: 100%;">Pedido finalizado</button>
                        <% } else { %>
                            <button class="btn-secondary" onclick="activateOrder(<%= order.id %>)" style="width: 100%;">Ativar Pedido</button>
                        <% } %>
                    </div>
                <% }) %>
            </div>
        </div>

    </div>

    <div class="footer">© 2026 Aalthair's Food • Dashboard Administrativo</div>
</div>

<script>
    // Função para ativar pedido (já existente)
    async function activateOrder(id) {
        try {
            const response = await fetch('/activate-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
            });
            if (response.ok) {
                location.reload(); 
            } else {
                alert('Erro ao ativar pedido');
            }
        } catch (error) {
            alert('Erro de rede: ' + error.message);
        }
    }

    // Nova Função para criar um pedido rápido a partir de um item
    async function createQuickOrder(itemId, itemName) {
        // Pede o nome do cliente usando um prompt simples
        const customerName = prompt(`Criar pedido para a marmita: ${itemName}\nNome do Cliente:`, "Cliente Balcão");
        
        // Se o usuário clicar em Cancelar, aborta
        if (customerName === null) return;

        try {
            // Requisição POST para o backend
            const response = await fetch('/quick-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ item_id: itemId, customer_name: customerName })
            });
            
            const data = await response.json();
            
            if (data.success) {
                // Atualização visual na lista "Pedidos Recentes" (DOM Manipulation)
                const ordersContainer = document.getElementById('orders-container');
                
                // Remove a mensagem "Nenhum pedido no momento" se ela existir
                const emptyMsg = document.getElementById('empty-orders-msg');
                if (emptyMsg) {
                    emptyMsg.remove();
                }

                // Cria o HTML do novo pedido recém retornado do backend
                const newOrderHtml = `
                    <div class="item-row order-item">
                        <div class="order-header">
                            <div class="item-details" style="flex: 1;">
                                <div class="item-title">${data.customer_name}</div>
                                <div class="item-subtitle">Marmita: ${itemName}</div>
                            </div>
                            <div class="order-status">${data.status}</div>
                        </div>
                        <button class="btn-secondary" onclick="activateOrder(${data.orderId})" style="width: 100%;">Ativar Pedido</button>
                    </div>
                `;
                
                // Insere o novo pedido no final da lista
                ordersContainer.insertAdjacentHTML('beforeend', newOrderHtml);
                
            } else {
                alert('Erro ao criar pedido: ' + data.error);
            }
        } catch (error) {
            alert('Erro de rede: ' + error.message);
        }
    }
</script>
</body>
</html>
